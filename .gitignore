# Secrets
.kaggle/
*.json.key
kaggle.json

# Data / large assets (ignore downloads, keep our reference docs)
data/*
!data/*.md
data/traces/
*.zip
*.csv.gz

# Python
__pycache__/
*.pyc
.venv/
venv/

# Scratch
dist/
!dist/candidates/
dist/submission_build/
build/
*.log
report/agent_logs/*.json
report/replays/*.json
report/local_replays/*.json
report/az/
**/*.pth
.DS_Store

# Large downloaded Kaggle reference (episodes/notebooks) — keep out of git
data/kaggle_ref/episodes/
data/kaggle_ref/*.ipynb

# Local IDE / agent settings
.claude/

# Trained policy weights (reproducible from train scripts)
agent/models/*.npz
agent/models/rl_policy.zip
agent/models/rl_policy_campaign.zip

# Runtime eval / gate outputs (regenerated)
report/public_gate/
report/submission_stats/
report/rl_deck_campaign/population/
report/_model_backup_*/
